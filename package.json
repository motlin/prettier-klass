{
  "name": "prettier-plugin-klass",
  "version": "0.1.0",
  "description": "Prettier plugin that formats the Klass DSL, including ```klass fenced blocks in Markdown",
  "type": "module",
  "license": "MIT",
  "author": "Craig Motlin <cmotlin@gmail.com>",
  "keywords": [
    "prettier",
    "prettier-plugin",
    "klass",
    "formatter",
    "tree-sitter",
    "dsl"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/motlin/prettier-klass.git"
  },
  "homepage": "https://github.com/motlin/prettier-klass#readme",
  "bugs": {
    "url": "https://github.com/motlin/prettier-klass/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "klass.wasm",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate": "tree-sitter generate",
    "build:wasm": "tree-sitter build --wasm --output klass.wasm .",
    "grammar": "npm run generate && npm run build:wasm",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "lint": "oxlint",
    "lint:ci": "oxlint --format github",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "web-tree-sitter": "^0.25.10"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "markdownlint-cli2": "^0.18.0",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "tree-sitter-cli": "^0.25.10",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
